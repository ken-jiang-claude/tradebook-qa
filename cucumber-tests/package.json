{
  "name": "tradebook-qa-cucumber",
  "version": "1.0.0",
  "description": "Bloomberg TradeBook QA — Cucumber BDD test suite (Playwright + manual mode)",
  "type": "module",
  "scripts": {
    "test": "cucumber-js --profile default",
    "test:manual": "cucumber-js --profile manual",
    "test:smoke": "cucumber-js --profile smoke",
    "test:lifecycle": "cucumber-js --profile lifecycle",
    "test:environment": "cucumber-js --profile environment",
    "test:headed": "HEADLESS=false cucumber-js --profile default",
    "test:dry": "cucumber-js --profile default --dry-run",
    "test:edge": "cucumber-js --profile edgeCases",
    "report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.8.0",
    "@playwright/test": "^1.44.0",
    "chalk": "^5.3.0",
    "cucumber-html-reporter": "^7.1.1",
    "dotenv": "^16.4.5",
    "playwright": "^1.44.0",
    "wait-on": "^7.2.0"
  }
}
